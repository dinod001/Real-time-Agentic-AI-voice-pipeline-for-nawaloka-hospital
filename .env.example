# ============================================================================
# Nawaloka Hospital AI — Environment Variables
# ============================================================================
# Copy this file to .env and fill in real values. Never commit .env.

# ── Supabase (PostgreSQL + pgvector) ────────────────────────────────────
# Use the Pooler URL (port 6543), not the direct DB URL (5432).
SUPABASE_DB_URL=postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_KEY=

# ── Qdrant Cloud (vector store for RAG + CAG) ──────────────────────────
QDRANT_URL=https://<cluster>.cloud.qdrant.io
QDRANT_API_KEY=

# ── LLM Providers ───────────────────────────────────────────────────────
# OpenRouter is the default unified gateway; Groq is used for the fast
# guardrail/extractor LLM; OpenAI is used for embeddings.
OPENROUTER_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# ── Web Search (Tavily) ─────────────────────────────────────────────────
TAVILY_API_KEY=

# ── LangFuse Observability (optional) ──────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# ============================================================================
# Voice Pipeline (Week 14) — LiveKit Cloud + Deepgram
# ============================================================================
# Required only if you run `make voice` (native worker) or
# `make demo-voice` (Docker stack with the voice profile).
# This week we use LiveKit Cloud (free tier); a local livekit-server is
# planned for Week 15.

# LiveKit Cloud project — get from https://cloud.livekit.io
LIVEKIT_URL=wss://<your-project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Deepgram (STT) — get from https://console.deepgram.com
DEEPGRAM_API_KEY=

# ElevenLabs (TTS) — get from https://elevenlabs.io/app/settings/api-keys
# Default tts_provider in param.yaml is `elevenlabs`. Switch to `deepgram`
# in param.yaml if you don't want to use ElevenLabs.
ELEVEN_API_KEY=
